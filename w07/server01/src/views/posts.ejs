<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Posts</title>
</head>

<body>
    <h1>Posts</h1>
    <a href="/posts/create">Create Posts</a>
    <ul>
        <% posts.forEach(post=> { %>
            <li>
                <a href="/posts/<%= post._id %>">
                    <%= post.title %>
                </a>
            </li>
            <% }) %>
    </ul>
</body>

</html>